{
  "request": {
    "method": "POST",
    "url": "/ledger/v1/accounts/check"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "transformers": ["response-template"],
    "jsonBody": {
      "accounts": {
        "{{jsonPath request.body '$.ids[0]'}}": {
          "accountId": "{{jsonPath request.body '$.ids[0]'}}",
          "currency": "USD",
          "status": "ACTIVE"
        },
        "{{jsonPath request.body '$.ids[1]'}}": {
          "accountId": "{{jsonPath request.body '$.ids[1]'}}",
          "currency": "USD",
          "status": "ACTIVE"
        }
      },
      "missing": []
    }
  }
}
